REDIS_IMAGE=redis:7-alpine
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=changeme
JOB_QUEUE_NAME=jobs:queue
JOB_STATUS_PREFIX=job
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api:8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
WORKER_POLL_TIMEOUT=5
WORKER_JOB_DELAY_SECONDS=2
WORKER_HEARTBEAT_FILE=/tmp/worker-heartbeat
WORKER_HEARTBEAT_TTL_SECONDS=30
COMPOSE_NETWORK_NAME=hng-stage2-network
REDIS_CPU_LIMIT=0.50
REDIS_MEMORY_LIMIT=256m
API_CPU_LIMIT=0.50
API_MEMORY_LIMIT=256m
WORKER_CPU_LIMIT=0.50
WORKER_MEMORY_LIMIT=256m
FRONTEND_CPU_LIMIT=0.50
FRONTEND_MEMORY_LIMIT=256m
IMAGE_REGISTRY=localhost:5000
IMAGE_TAG=latest
API_IMAGE=localhost:5000/hng-stage2-api:latest
WORKER_IMAGE=localhost:5000/hng-stage2-worker:latest
FRONTEND_IMAGE=localhost:5000/hng-stage2-frontend:latest
